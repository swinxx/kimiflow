{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/active-run.sh prompt-context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/commit-secret-gate.sh"
          },
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/state-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/test-gate.sh"
          },
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/active-run.sh stop-gate"
          },
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/map-staleness-nudge.sh"
          },
          {
            "type": "command",
            "command": "${KIMIFLOW_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/improvements-staleness-nudge.sh"
          }
        ]
      }
    ]
  }
}
